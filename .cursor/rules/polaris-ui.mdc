## Modal for destructive actions
```tsx
<Modal
  open={showDeleteModal}
  onClose={() => setShowDeleteModal(false)}
  title="Delete bundle?"
  primaryAction={{
    content: "Delete",
    destructive: true,
    onAction: handleDelete
  }}
  secondaryActions={[{
    content: "Cancel",
    onAction: () => setShowDeleteModal(false)
  }]}
>
  <Modal.Section>
    <Text>This will permanently delete "{bundle.name}". This cannot be undone.</Text>
  </Modal.Section>
</Modal>
```

## Plan gate component
```tsx
// Show upgrade prompt when feature is locked
function PlanGate({ requiredPlan, currentPlan, children }) {
  const hasAccess = PLAN_HIERARCHY[currentPlan] >= PLAN_HIERARCHY[requiredPlan];
  
  if (!hasAccess) {
    return (
      <Banner
        title={`${requiredPlan} plan required`}
        action={{ content: "Upgrade now", url: "/app/billing" }}
        tone="warning"
      >
        <p>This feature is available on the {requiredPlan} plan and above.</p>
      </Banner>
    );
  }
  
  return children;
}
```

## Onboarding wizard
```tsx
// 3-step progress wizard
const steps = ["Welcome", "Create bundle", "Go live"];

<Card>
  <BlockStack gap="600">
    {/* Progress steps */}
    <InlineStack gap="400" align="center">
      {steps.map((step, i) => (
        <InlineStack key={step} gap="200" blockAlign="center">
          <Box
            background={i <= currentStep ? "bg-fill-success" : "bg-fill-secondary"}
            borderRadius="full"
            padding="100"
            width="24px"
          >
            <Text alignment="center" tone={i <= currentStep ? "magic" : "subdued"}>
              {i < currentStep ? "✓" : i + 1}
            </Text>
          </Box>
          <Text tone={i === currentStep ? "base" : "subdued"}>{step}</Text>
          {i < steps.length - 1 && <Divider borderColor="border" />}
        </InlineStack>
      ))}
    </InlineStack>
    
    {/* Step content */}
    {currentStep === 0 && <WelcomeStep />}
    {currentStep === 1 && <CreateBundleStep />}
    {currentStep === 2 && <GoLiveStep />}
    
    {/* Navigation */}
    <InlineStack align="end" gap="300">
      {currentStep > 0 && (
        <Button onClick={() => setStep(s => s - 1)}>Back</Button>
      )}
      <Button
        variant="primary"
        onClick={() => currentStep < 2 ? setStep(s => s + 1) : completeOnboarding()}
      >
        {currentStep === 2 ? "Finish setup" : "Continue"}
      </Button>
    </InlineStack>
  </BlockStack>
</Card>
```
