```liquid
{{- 'bundle-widget.css' | asset_url | stylesheet_tag -}}

<div
  id="velora-bundle-widget"
  data-shop="{{ shop.permanent_domain }}"
  data-product-id="{{ product.id }}"
  data-position="{{ block.settings.position }}"
>
  <div class="velora-skeleton">Loading bundles...</div>
</div>

<script src="{{ 'bundle-widget.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Velora Bundle Widget",
  "target": "section",
  "settings": [
    {
      "type": "select",
      "id": "position",
      "label": "Widget position",
      "options": [
        { "value": "above_atc", "label": "Above Add to Cart" },
